# Plex Streams Monitor Configuration
# Copy this file to /opt/apps/compose/.env and fill in your values

# Plex server URL
# Default: http://localhost:32400
PLEX_URL=http://localhost:32400

# Plex authentication token (REQUIRED)
# How to get your token:
# 1. Open Plex Web App (app.plex.tv)
# 2. Play any media
# 3. Click ... → Get Info → View XML
# 4. Copy X-Plex-Token value from URL
PLEX_TOKEN=your-plex-token-here

# Example for remote server:
# PLEX_URL=http://192.168.1.100:32400
# PLEX_TOKEN=REMOVED_SECRET

# Example for HTTPS:
# PLEX_URL=https://plex.yourdomain.com:32400
# PLEX_TOKEN=your-token-here
