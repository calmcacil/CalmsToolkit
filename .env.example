# CalmsToolkit Configuration
# Copy this file to /opt/apps/compose/.env and fill in your values

# =============================================================================
# Plex Streams Monitor Configuration
# =============================================================================

# Plex server URL
# Default: http://localhost:32400
PLEX_URL=http://localhost:32400

# Plex authentication token (REQUIRED)
# How to get your token:
# 1. Open Plex Web App (app.plex.tv)
# 2. Play any media
# 3. Click ... → Get Info → View XML
# 4. Copy X-Plex-Token value from URL
PLEX_TOKEN=your-plex-token-here

# Example for remote server:
# PLEX_URL=http://192.168.1.100:32400
# PLEX_TOKEN=abc123xyz789def456ghi012jkl345mno678

# Example for HTTPS:
# PLEX_URL=https://plex.yourdomain.com:32400
# PLEX_TOKEN=your-token-here

# =============================================================================
# Jellyfin Streams Monitor Configuration
# =============================================================================

# Jellyfin server URL
# Default: http://localhost:8096
JELLYFIN_URL=http://localhost:8096

# Jellyfin API token (REQUIRED)
# How to get your token:
# 1. Open Jellyfin web interface
# 2. Go to Dashboard → API Keys
# 3. Click "+" to create new API key
# 4. Copy the generated token
JELLYFIN_TOKEN=your-jellyfin-token-here

# Example for remote server:
# JELLYFIN_URL=http://192.168.1.100:8096
# JELLYFIN_TOKEN=abc123xyz789def456ghi012jkl345mno678

# =============================================================================
# Sonarr Calendar Configuration (for media-calendar)
# =============================================================================

# Sonarr server URLs (comma-separated for multiple instances)
# Default: http://localhost:8989
# For multiple instances (e.g., HD and 4K), separate with commas
SONARR_URLS=http://localhost:8989

# Sonarr API tokens (comma-separated, must match order of URLs)
# How to get your API key:
# 1. Open Sonarr web interface
# 2. Settings → General → Security → API Key
# 3. Copy the API key
SONARR_TOKENS=your-sonarr-token-here

# Example for multiple instances:
# SONARR_URLS=http://sonarr-hd:8989,http://sonarr-4k:8989
# SONARR_TOKENS=token-for-hd-instance,token-for-4k-instance

# =============================================================================
# Radarr Calendar Configuration (for media-calendar)
# =============================================================================

# Radarr server URLs (comma-separated for multiple instances)
# Default: http://localhost:7878
# For multiple instances (e.g., HD and 4K), separate with commas
RADARR_URLS=http://localhost:7878

# Radarr API tokens (comma-separated, must match order of URLs)
# How to get your API key:
# 1. Open Radarr web interface
# 2. Settings → General → Security → API Key
# 3. Copy the API key
RADARR_TOKENS=your-radarr-token-here

# Example for multiple instances:
# RADARR_URLS=http://radarr-hd:7878,http://radarr-4k:7878
# RADARR_TOKENS=token-for-hd-instance,token-for-4k-instance

# =============================================================================
# Sonarr/Radarr Feed Configuration (for arr-feed)
# =============================================================================

# Sonarr server URLs (comma-separated, reuses Sonarr config above)
# Uses SONARR_URLS and SONARR_TOKENS from calendar configuration

# Radarr server URLs (comma-separated, reuses Radarr config above)  
# Uses RADARR_URLS and RADARR_TOKENS from calendar configuration

# Poll interval for watch mode (default: 5s)
ARR_FEED_POLL_INTERVAL=5s

# History lookback window (default: 1h)
ARR_FEED_HISTORY_DURATION=1h

# HTTP request timeout (default: 30s)
ARR_FEED_TIMEOUT=30s

# Example usage:
# arr-feed -watch                    # Watch mode with defaults
# arr-feed -duration 24h             # Show last 24 hours
# arr-feed -json                     # Output JSON format
# arr-feed -show-imported=false      # Hide imported events

# =============================================================================
# Notes
# =============================================================================
# - All tokens are REQUIRED for their respective tools to function
# - URLs should not have trailing slashes
# - For multi-instance setups, tokens must match the order of URLs
# - The media-calendar tool will deduplicate shows/movies across instances
